function renderBreeds(list){
  const tbody=document.getElementById('breedBody');
  tbody.innerHTML=list.map(function(b){
    var clipCell=b.clip?'<span class="price-val">'+b.clip+'</span>':'<span class="price-na">—</span>';
    var stripCell=b.strip?'<span class="strip-badge">'+b.strip+'</span>':'<span class="price-na">—</span>';
    var bathCell=b.bath?'<span class="price-val">'+b.bath+'</span>':'<span class="price-na">—</span>';
    return '<tr><td class="breed-name">'+b.name+'</td><td>'+clipCell+'</td><td>'+stripCell+'</td><td>'+bathCell+'</td></tr>';
  }).join('');
}

function renderExtras(){
  document.getElementById('extrasGrid').innerHTML=extras.map(function(e){
    return '<div class="extra-card"><span class="extra-name">'+e.name+'</span><span class="extra-price">'+e.price+'</span></div>';
  }).join('');
}

function renderSpecials(){
  document.getElementById('specialCards').innerHTML=specials.map(function(s){
    return '<div class="special-card"><h3>'+s.title+'</h3><p>'+s.desc+'</p><div class="price">'+s.price+'</div></div>';
  }).join('');
}

function filterBreeds(q){
  var filtered=q.trim()===''?breeds:breeds.filter(function(b){return b.name.toLowerCase().indexOf(q.toLowerCase())>-1;});
  renderBreeds(filtered);
  // switch to breeds tab if not already
  showTab('breeds');
}

function showTab(id){
  document.querySelectorAll('.tab-content').forEach(function(el){el.classList.remove('active');});
  document.querySelectorAll('.header-tab').forEach(function(el){el.classList.remove('active');});
  document.getElementById('tab-'+id).classList.add('active');
  var tabs=['breeds','extras','special'];
  document.querySelectorAll('.header-tab')[tabs.indexOf(id)].classList.add('active');
}

renderBreeds(breeds);
